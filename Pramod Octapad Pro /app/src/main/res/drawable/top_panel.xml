<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer Glow -->
    <item>
        <shape>
            <solid android:color="#02070F"/>

            <corners android:radius="8dp"/>

            <stroke
                android:width="3dp"
                android:color="#00AFFF"/>
        </shape>
    </item>

    <!-- Inner Border -->
    <item
        android:left="3dp"
        android:right="3dp"
        android:top="3dp"
        android:bottom="3dp">

        <shape>
            <gradient
                android:startColor="#000A15"
                android:endColor="#001A33"
                android:angle="270"/>

            <corners android:radius="6dp"/>

            <stroke
                android:width="1dp"
                android:color="#66CCFF"/>
        </shape>
    </item>

</layer-list>
