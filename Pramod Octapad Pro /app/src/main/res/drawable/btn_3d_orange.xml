<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="2dp" android:left="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient android:startColor="#994C00" android:endColor="#E67300" android:angle="270"/>
                    <stroke android:width="1dp" android:color="#FFB266"/>
                    <padding android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="3dp" android:left="3dp"><shape><corners android:radius="6dp"/><solid android:color="#77000000"/></shape></item>
            <item android:bottom="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient android:startColor="#FF9933" android:endColor="#CC6600" android:angle="270"/>
                    <stroke android:width="1dp" android:color="#88FFFFFF"/>
                    <padding android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp"/>
                </shape>
            </item>
            <item android:bottom="3dp" android:right="3dp">
                <shape><corners android:radius="6dp"/><gradient android:startColor="#77FFFFFF" android:centerColor="#11FFFFFF" android:centerY="0.3" android:endColor="#00FFFFFF" android:angle="270"/></shape>
            </item>
            <item android:bottom="3dp" android:right="3dp">
                 <shape><corners android:radius="6dp"/><gradient android:startColor="#00000000" android:centerY="0.7" android:endColor="#AA000000" android:angle="270"/></shape>
            </item>
        </layer-list>
    </item>
</selector>