<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow -->
    <item
        android:left="5dp"
        android:top="5dp">

        <shape android:shape="rectangle">
            <solid android:color="#88000000"/>
            <corners android:radius="20dp"/>
        </shape>

    </item>

    <!-- Outer Glow Border -->
    <item>

        <shape android:shape="rectangle">

            <corners android:radius="20dp"/>

            <solid android:color="#001020"/>

            <stroke
                android:width="4dp"
                android:color="#00DFFF"/>

        </shape>

    </item>

    <!-- Main Pad -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">

        <shape android:shape="rectangle">

            <gradient
                android:startColor="#4DE1FF"
                android:centerColor="#0099FF"
                android:endColor="#003DCC"
                android:angle="270"/>

            <corners android:radius="18dp"/>

            <stroke
                android:width="2dp"
                android:color="#AAFFFF"/>

        </shape>

    </item>

</layer-list>
