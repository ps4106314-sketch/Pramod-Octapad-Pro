<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="#020A25"/>
            <stroke
                android:width="3dp"
                android:color="#00D4FF"/>
        </shape>
    </item>

    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">

        <shape>
            <solid android:color="#041540"/>
            <stroke
                android:width="2dp"
                android:color="#66E5FF"/>
        </shape>
    </item>

</layer-list>
