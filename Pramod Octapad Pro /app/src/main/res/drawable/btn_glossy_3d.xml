<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED STATE -->
    <item android:state_pressed="true">
        <layer-list>
            <!-- 3D Shadow Push Down -->
            <item android:top="2dp" android:left="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#99004C"
                        android:centerColor="#4C0099"
                        android:endColor="#004C99"
                        android:angle="45"/>
                    <stroke android:width="1dp" android:color="#AAFFFFFF"/>
                    <padding android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- NORMAL STATE -->
    <item>
        <layer-list>
            <!-- Drop Shadow for 3D depth -->
            <item android:top="3dp" android:left="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <solid android:color="#77000000"/>
                </shape>
            </item>

            <!-- Multi-Color Vibrant Base -->
            <item android:bottom="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#FF007A"
                        android:centerColor="#9D00FF"
                        android:endColor="#00D4FF"
                        android:angle="135"/>
                    <stroke android:width="1dp" android:color="#CCFFFFFF"/>
                    <padding android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp"/>
                </shape>
            </item>

            <!-- Glossy Shine Overlay -->
            <item android:bottom="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#77FFFFFF"
                        android:centerColor="#11FFFFFF"
                        android:centerY="0.4"
                        android:endColor="#00FFFFFF"
                        android:angle="270"/>
                </shape>
            </item>
            
            <!-- Bottom Dark Bevel -->
            <item android:bottom="3dp" android:right="3dp">
                 <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#00000000"
                        android:centerColor="#00000000"
                        android:centerY="0.6"
                        android:endColor="#55000000"
                        android:angle="270"/>
                 </shape>
            </item>

        </layer-list>
    </item>

</selector>