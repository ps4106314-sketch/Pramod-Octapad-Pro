<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- OUTER FRAME -->
    <item>
        <shape android:shape="rectangle">

            <solid android:color="#010814"/>

            <corners android:radius="24dp"/>

            <stroke
                android:width="5dp"
                android:color="#00FFFF"/>

        </shape>
    </item>

    <!-- GLOW BORDER -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">

        <shape android:shape="rectangle">

            <solid android:color="#02102A"/>

            <corners android:radius="22dp"/>

            <stroke
                android:width="3dp"
                android:color="#66FFFF"/>

        </shape>

    </item>

    <!-- INNER PANEL -->
    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">

        <shape android:shape="rectangle">

            <gradient
                android:startColor="#082A88"
                android:centerColor="#041A55"
                android:endColor="#020A25"
                android:angle="270"/>

            <corners android:radius="18dp"/>

            <stroke
                android:width="2dp"
                android:color="#99FFFF"/>

        </shape>

    </item>

</layer-list>
